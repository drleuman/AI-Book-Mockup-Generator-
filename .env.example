
# =========================
# FRONTEND (VITE)
# =========================

# Puerto local del frontend Vite
VITE_PORT=5174

# Target del BFF en desarrollo para el proxy de Vite
VITE_BFF_TARGET=http://localhost:8790


# =========================
# BACKEND / BFF
# =========================

# Puerto del servidor BFF
SERVER_PORT=8790

# Origen permitido del frontend
APP_ORIGIN=http://localhost:5174

# API key real del proveedor.
# Nunca exponer esta clave en variables VITE_*.
GEMINI_API_KEY=your_real_server_side_key_here

# Límites de upload
MAX_UPLOAD_BYTES=10485760
MIN_IMAGE_WIDTH=200
MIN_IMAGE_HEIGHT=200
MAX_IMAGE_WIDTH=12000
MAX_IMAGE_HEIGHT=12000

# Rate limits - generación individual
RATE_LIMIT_SINGLE_MAX=8
RATE_LIMIT_SINGLE_WINDOW_MS=60000

# Rate limits - batch generation
RATE_LIMIT_BATCH_MAX=3
RATE_LIMIT_BATCH_WINDOW_MS=300000

# Máximo de previews por batch
MAX_BATCH_PREVIEWS=5


# =========================
# NODE / RUNTIME
# =========================

NODE_ENV=development
